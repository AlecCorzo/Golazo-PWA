PORT=3000

# Claves VAPID para Web Push
# Generarlas con: node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:tu_correo@ejemplo.com

# Configuración Firebase (cliente) — obtenerla en console.firebase.google.com
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
